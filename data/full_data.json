,\n    \"oculto_no_organograma\": false,\n    \"is_agrupamento\": false,\n    \"layout_filhos\": \"V\"\n  }\n},\n{\n  \"model\": \"core.unit\",\n  \"pk\": 2587,\n  \"fields\": {\n    \"organograma\": 57,\n    \"unidade_pai\": 2535,\n    \"source_unit\": null,\n    \"origem_modelo\": null,\n    \"nome_unidade\": \"Assessoria de Integridade e Normas\",\n    \"sigla_unidade\": \"RE-ASINT\",\n    \"tipo_unidade\": 3,\n    \"cargo_funcao_ref\": 4,\n    \"cargo_funcao\": \"\",\n    \"sigla_cargo\": \"\",\n    \"atribuicoes\": null,\n    \"ordem\": 8,\n    \"ligacao_indireta\": true,\n    \"oculto_no_organograma\": false,\n    \"is_agrupamento\": false,\n    \"layout_filhos\": \"V\"\n  }\n},\n{\n  \"model\": \"core.unit\",\n  \"pk\": 2588,\n  \"fields\": {\n    \"organograma\": 57,\n    \"unidade_pai\": 2537,\n    \"source_unit\": null,\n    \"origem_modelo\": null,\n    \"nome_unidade\": \"Diretoria de Gestão Estratégica e Desenvolvimento Institucional\",\n    \"sigla_unidade\": \"RE-DDI\",\n    \"tipo_unidade\": 3,\n    \"cargo_funcao_ref\": 4,\n    \"cargo_funcao\": null,\n    \"sigla_cargo\": \"\",\n    \"atribuicoes\": null,\n    \"ordem\": 8,\n    \"ligacao_indireta\": false,\n    \"oculto_no_organograma\": false,\n    \"is_agrupamento\": false,\n    \"layout_filhos\": \"V\"\n  }\n},\n{\n  \"model\": \"core.unit\",\n  \"pk\": 2589,\n  \"fields\": {\n    \"organograma\": 57,\n    \"unidade_pai\": 2535,\n    \"source_unit\": null,\n    \"origem_modelo\": null,\n    \"nome_unidade\": \"Auditoria Interna\",\n    \"sigla_unidade\": \"RE-AUDIN\",\n    \"tipo_unidade\": 11,\n    \"cargo_funcao_ref\": null,\n    \"cargo_funcao\": \"Auditor(a) Interno\",\n    \"sigla_cargo\": \"FG-01\",\n    \"atribuicoes\": \"A Auditoria Interna, vinculada ao IFMG-Reitoria, constitui unidade de\\r\\nassessoramento responsável por avaliar, fortalecer e apoiar os processos de\\r\\ngovernança, de gerenciamento de riscos e de controles internos, contribuindo para a\\r\\nmelhoria contínua da gestão institucional.\\r\\n\\r\\nCompete à Auditoria Interna:\\r\\n\\r\\nI  analisar os procedimentos administrativos, rotinas e mecanismos de controle\\r\\ninterno, com vistas à conformidade e à regularidade dos atos de gestão;\\r\\nII  avaliar a eficiência, a eficácia, a efetividade e a economicidade na aplicação dos\\r\\nrecursos públicos, promovendo a integridade e a boa governança;\\r\\nIII  examinar a consistência, a fidedignidade e a adequação dos registros contábeis\\r\\ne das demonstrações financeiras;\\r\\nIV  prestar apoio técnico e fornecer informações aos órgãos integrantes do Sistema\\r\\nde Controle Interno do Poder Executivo Federal, bem como ao Tribunal de Contas da\\r\\nUnião (TCU);\\r\\nV  realizar auditorias internas periódicas na Reitoria e nos campi do IFMG, em\\r\\nconformidade com o Plano Anual de Auditoria Interna (PAINT) e com as normas\\r\\nResolução do Conselho Superior 46 (2512991) SEI 23208.002008/2025-46 / pg. 6\\r\\nexpedidas pelos órgãos de controle;\\r\\nVI  coordenar, supervisionar e acompanhar os trabalhos de auditoria desenvolvidos\\r\\nnas unidades descentralizadas do IFMG;\\r\\nVII  examinar e emitir parecer prévio sobre a prestação de contas anual da gestão\\r\\ndo IFMG, bem como sobre processos de tomada de contas especial;\\r\\nVIII  acompanhar a elaboração e a tempestiva apresentação das respostas e\\r\\ninformações solicitadas pela Controladoria-Geral da União (CGU) e pelo Tribunal de\\r\\nContas da União (TCU);\\r\\nIX  recomendar a adoção de medidas preventivas e corretivas destinadas ao\\r\\naperfeiçoamento dos processos de gestão, ao fortalecimento dos controles internos\\r\\ne à mitigação de riscos.\\r\\nX  realizar atividades de avaliação e de consultoria, no âmbito de sua competência,\\r\\natuando como terceira linha de defesa da governança institucional, com\\r\\nindependência técnica, imparcialidade e objetividade.\",\n    \"ordem\": 9,\n    \"ligacao_indireta\": true,\n    \"oculto_no_organograma\": false,\n    \"is_agrupamento\": false,\n    \"layout_filhos\": \"V\"\n  }\n},\n{\n  \"model\": \"core.unit\",\n  \"pk\": 2590,\n  \"fields\": {\n    \"organograma\": 57,\n    \"unidade_pai\": 2535,\n    \"source_unit\": null,\n    \"origem_modelo\": null,\n    \"nome_unidade\": \"Corregedoria\",\n    \"sigla_unidade\": \"RE-CORREG\",\n    \"tipo_unidade\": 11,\n    \"cargo_funcao_ref\": null,\n    \"cargo_funcao\": \"Corregedor(a)\",\n    \"sigla_cargo\": \"CD-04\",\n    \"atribuicoes\": null,\n    \"ordem\": 10,\n    \"ligacao_indireta\": true,\n    \"oculto_no_organograma\": false,\n    \"is_agrupamento\": false,\n    \"layout_filhos\": \"V\"\n  }\n},\n{\n  \"model\": \"core.unit\",\n  \"pk\": 2591,\n  \"fields\": {\n    \"organograma\": 57,\n    \"unidade_pai\": 2535,\n    \"source_unit\": null,\n    \"origem_modelo\": null,\n    \"nome_unidade\": \"Ouvidoria\",\n    \"sigla_unidade\": \"RE-OUV\",\n    \"tipo_unidade\": 11,\n    \"cargo_funcao_ref\": null,\n    \"cargo_funcao\": \"Ouvidor(a)\",\n    \"sigla_cargo\": \"FG-01\",\n    \"atribuicoes\": null,\n    \"ordem\": 11,\n    \"ligacao_indireta\": true,\n    \"oculto_no_organograma\": false,\n    \"is_agrupamento\": false,\n    \"layout_filhos\": \"V\"\n  }\n},\n{\n  \"model\": \"core.unit\",\n  \"pk\": 2592,\n  \"fields\": {\n    \"organograma\": 57,\n    \"unidade_pai\": 2583,\n    \"source_unit\": null,\n    \"origem_modelo\": null,\n    \"nome_unidade\": \"Diretoria de Diversidade, Desenvolvimento e Qualidade de Vida\",\n    \"sigla_unidade\": \"RE-DIDEQ\",\n    \"tipo_unidade\": 3,\n    \"cargo_funcao_ref\": 4,\n    \"cargo_funcao\": \"\",\n    \"sigla_cargo\": \"\",\n    \"atribuicoes\": null,\n    \"ordem\": 2,\n    \"ligacao_indireta\": false,\n    \"oculto_no_organograma\": false,\n    \"is_agrupamento\": false,\n    \"layout_filhos\": \"V\"\n  }\n},\n{\n  \"model\": \"core.unit\",\n  \"pk\": 2593,\n  \"fields\": {\n    \"organograma\": 57,\n    \"unidade_pai\": 2592,\n    \"source_unit\": null,\n    \"orige