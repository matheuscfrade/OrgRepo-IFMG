# =============================================================================
# OrgRepo - Environment Configuration Example (Prototype)
#
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.
#
# This is a prototype. For institutional use, replace the development
# defaults with proper corporate secrets and configuration.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=your-super-secret-key-here-generate-with-django-utils
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Environment name (used by settings logic)
DJANGO_ENV=development          # development | production | test

# -----------------------------------------------------------------------------
# Database (PostgreSQL recommended for production)
# For local dev with Docker Compose, the example below works out of the box.
# For native Postgres: update host/port/user/pass accordingly.
# Fallback to SQLite is handled in settings for pure local quick starts.
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://orgrepo:devpassword@localhost:5432/orgrepo

# Alternative individual vars (if you prefer not to use DATABASE_URL)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=orgrepo
# DB_USER=orgrepo
# DB_PASSWORD=devpassword
# DB_HOST=localhost
# DB_PORT=5432

# -----------------------------------------------------------------------------
# Static & Media (for production / object storage)
# -----------------------------------------------------------------------------
# When using django-storages + S3/MinIO in production
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_STORAGE_BUCKET_NAME=orgrepo-media
# AWS_S3_ENDPOINT_URL=          # for MinIO or custom S3-compatible
# AWS_S3_REGION_NAME=auto

# -----------------------------------------------------------------------------
# Optional: Email (for future notifications / password reset)
# -----------------------------------------------------------------------------
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=...
# EMAIL_HOST_PASSWORD=...
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@orgrepo.ifmg.edu.br

# -----------------------------------------------------------------------------
# Optional: Logging / Observability
# -----------------------------------------------------------------------------
# SENTRY_DSN=...

# -----------------------------------------------------------------------------
# Docker / Production
# -----------------------------------------------------------------------------
POSTGRES_DB=orgrepo
POSTGRES_USER=orgrepo
POSTGRES_PASSWORD=change-this-password

# For production, set these:
# SECRET_KEY=your-very-long-random-secret-key
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# -----------------------------------------------------------------------------
# Notes for this project
# -----------------------------------------------------------------------------
# - The "Manual Test Sandbox" (second DB + orange banner) can be activated
#   by setting DJANGO_SETTINGS_MODULE=config.settings_manual_test (or equivalent
#   override in your layered settings) and running on a different port.
# - Media files (PDF regimentos/resoluções) are intentionally NOT committed.
#   After first setup you must upload them via Django admin or the bootstrap tools.
